{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",                 // Changed from "commonjs" to "Node16"
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "Node16",       // Keep as Node16
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
    // Remove "ignoreDeprecations" completely
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}